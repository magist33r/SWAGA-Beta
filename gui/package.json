{
  "name": "vip-gui",
  "version": "1.0.0",
  "description": "Desktop GUI for DayZ VIP manager",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev:renderer": "vite --config renderer/vite.config.js",
    "build:renderer": "vite build --config renderer/vite.config.js",
    "build": "npm run build:renderer && electron-builder --win portable"
  },
  "build": {
    "appId": "com.swaga.vipgui",
    "productName": "VIP Manager",
    "files": [
      "**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.5.0",
    "vite": "^7.3.1"
  }
}
